page {
  background: linear-gradient(180deg, #f6efe4 0%, #eadcc8 100%);
  min-height: 100%;
  color: #3a2b1a;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 32rpx;
}

/* 底部 TabBar */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  display: flex;
  background: rgba(255, 253, 248, 0.96);
  border-top: 1rpx solid #e8d5b8;
  z-index: 100;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #b8a48a;
  font-size: 20rpx;
  transition: color 0.15s;
}

.tab-item.active {
  color: #7a5834;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 2rpx;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 600;
}

/* 骨架屏 */
.skeleton-card {
  background: linear-gradient(90deg, #f0e6d6 25%, #f8f0e2 50%, #f0e6d6 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
