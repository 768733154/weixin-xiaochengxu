.result-page {
  padding-bottom: 48rpx;
}

.banner {
  margin-bottom: 24rpx;
  text-align: center;
}

.banner.pass {
  background: linear-gradient(180deg, #fff7dc 0%, #f5e6b8 100%);
}

.banner.fail {
  background: linear-gradient(180deg, #fff1ef 0%, #f7d6cf 100%);
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #5a4023;
}

.result-subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #775532;
}

.stats-card,
.record-card,
.ranking-card {
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  flex: 1;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #fff8ec;
}

.stat-label {
  font-size: 24rpx;
  color: #8b6742;
}

.stat-value {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #4a331b;
}

.reward-box {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f8eddc;
}

.reward-title,
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5a4023;
}

.reward-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #75522f;
}

.record-line {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #6d4f2e;
}

.ranking-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ead9bf;
}

.ranking-item:last-child {
  border-bottom: none;
}

.rank-no {
  width: 56rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #9a6a35;
}

.rank-main {
  flex: 1;
}

.rank-label {
  font-size: 28rpx;
  color: #4a331b;
}

.rank-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9c7b58;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d6a4f;
}

.empty-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #8b6e4a;
}

.action-group {
  display: flex;
  gap: 18rpx;
}

.primary-btn {
  flex: 1;
  background: #7a5834;
  color: #fff;
}

.secondary-btn {
  flex: 1;
  background: #2d6a4f;
  color: #fff;
}
