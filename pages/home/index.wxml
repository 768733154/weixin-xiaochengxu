<view class="container">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
  </block>

  <!-- 真实内容 -->
  <block wx:else>
    <!-- 用户栏 -->
    <view class="user-bar card" bindtap="onTapUser">
      <view class="user-avatar-text" wx:if="{{!userInfo.avatarUrl}}">👤</view>
      <image class="user-avatar" wx:elif="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-hint">{{userInfo.authorized ? '游戏达人' : '登录后查看排行榜'}}</text>
      </view>
    </view>

    <!-- 对战游戏 -->
    <block wx:if="{{pvpGames.length}}">
      <view class="section-title">
        <text class="section-icon">&#9876;</text>
        <text>对战游戏</text>
      </view>
      <view class="game-grid">
        <view
          class="game-card pvp-card"
          wx:for="{{pvpGames}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-path="{{item.path}}"
          bindtap="navigateToGame"
        >
          <view class="game-icon-wrap" style="background: {{item.color}}20;">
            <text class="game-icon-emoji">{{item.icon}}</text>
            <view class="pvp-badge">对战</view>
          </view>
          <text class="game-name">{{item.name}}</text>
          <view class="game-tags">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 单人游戏 -->
    <view class="section-title">
      <text class="section-icon">&#127918;</text>
      <text>单人游戏</text>
    </view>
    <view class="game-grid">
      <view
        class="game-card"
        wx:for="{{singleGames}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-path="{{item.path}}"
        bindtap="navigateToGame"
      >
        <view class="game-icon-wrap">
          <image class="game-icon" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <text class="game-name">{{item.name}}</text>
        <view class="game-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
        <text class="game-best" wx:if="{{bestScores[item.id]}}">最高 {{bestScores[item.id]}}</text>
      </view>
    </view>

    <!-- 底部占位，避免被 TabBar 遮挡 -->
    <view class="bottom-space"></view>
  </block>
</view>

<!-- 底部 Tab -->
<view class="tab-bar">
  <view class="tab-item active" data-tab="home" bindtap="switchTab">
    <text class="tab-icon">&#127968;</text>
    <text>游戏</text>
  </view>
  <view class="tab-item" data-tab="leaderboard" bindtap="switchTab">
    <text class="tab-icon">&#127942;</text>
    <text>排行榜</text>
  </view>
  <view class="tab-item" data-tab="profile" bindtap="switchTab">
    <text class="tab-icon">&#128100;</text>
    <text>我的</text>
  </view>
</view>
