<view class="page">
  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-row"></view>
    <view class="skeleton-row"></view>
    <view class="skeleton-row"></view>
    <view class="skeleton-row"></view>
  </block>

  <!-- 真实内容 -->
  <block wx:else>
    <!-- 用户栏 -->
    <view class="user-bar" bindtap="onTapUser">
      <view class="user-avatar-text" wx:if="{{!userInfo.avatarUrl}}">👤</view>
      <image class="user-avatar" wx:elif="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '点击设置昵称'}}</text>
        <text class="user-hint">{{userInfo.authorized ? '游戏达人' : '设置头像昵称，参与排行'}}</text>
      </view>
      <view class="user-arrow">›</view>
    </view>

    <!-- 对战游戏 -->
    <block wx:if="{{pvpGames.length}}">
      <view class="section-title">⚔ 对战游戏</view>
      <view class="game-list">
        <view
          class="game-row pvp-row"
          wx:for="{{pvpGames}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-path="{{item.path}}"
          bindtap="navigateToGame"
        >
          <view class="game-icon-box" style="background: {{item.color}}18;">
            <text class="game-emoji">{{item.icon}}</text>
          </view>
          <view class="game-detail">
            <view class="game-top">
              <text class="game-name">{{item.name}}</text>
              <view class="pvp-tag">⚔ 对战</view>
            </view>
            <view class="game-tags">
              <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
          </view>
          <text class="game-arrow">›</text>
        </view>
      </view>
    </block>

    <!-- 单人游戏 -->
    <view class="section-title">🎮 单人游戏</view>
    <view class="game-list">
      <view
        class="game-row"
        wx:for="{{singleGames}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-path="{{item.path}}"
        bindtap="navigateToGame"
      >
        <view class="game-icon-box" style="background: {{item.color}}18;">
          <text class="game-emoji">{{item.icon}}</text>
        </view>
        <view class="game-detail">
          <view class="game-top">
            <text class="game-name">{{item.name}}</text>
            <text class="game-best" wx:if="{{bestScores[item.id]}}">{{bestScores[item.id]}} 分</text>
          </view>
          <view class="game-tags">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>
        <text class="game-arrow">›</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-space"></view>
  </block>
</view>

<!-- 底部 Tab -->
<view class="tab-bar">
  <view class="tab-item active" data-tab="home" bindtap="switchTab">
    <text class="tab-icon">🏠</text>
    <text class="tab-label">游戏</text>
  </view>
  <view class="tab-item" data-tab="leaderboard" bindtap="switchTab">
    <text class="tab-icon">🏆</text>
    <text class="tab-label">排行榜</text>
  </view>
  <view class="tab-item" data-tab="profile" bindtap="switchTab">
    <text class="tab-icon">👤</text>
    <text class="tab-label">我的</text>
  </view>
</view>
