.user-bar {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #d8c3a5;
  background: #f0e6d6;
}

.user-avatar-text {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #d8c3a5;
  background: #f0e6d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-info {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #3a2b1a;
}

.user-hint {
  font-size: 24rpx;
  color: #9a8468;
  margin-top: 4rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #5a4023;
  margin-bottom: 20rpx;
  margin-top: 12rpx;
}

.section-icon {
  margin-right: 10rpx;
  font-size: 34rpx;
}

.game-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.game-card {
  width: calc(50% - 10rpx);
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #d8c3a5;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(58, 43, 26, 0.06);
  transition: transform 0.15s;
}

.game-card:active {
  transform: scale(0.96);
}

.pvp-card {
  border-color: #c97a3e;
  background: linear-gradient(180deg, #fff8ed 0%, #fef0da 100%);
}

.game-icon-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
}

.game-icon-emoji {
  font-size: 52rpx;
}

.pvp-badge {
  position: absolute;
  top: -6rpx;
  right: -16rpx;
  background: #c97a3e;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.game-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3a2b1a;
  margin-bottom: 8rpx;
}

.game-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.tag {
  font-size: 20rpx;
  color: #9a8468;
  background: #f0e6d6;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}

.game-best {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #c97a3e;
  font-weight: 600;
}

.bottom-space {
  height: 140rpx;
}
