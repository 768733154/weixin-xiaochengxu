.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6efe4 0%, #eadcc8 100%);
  padding: 0 28rpx;
}

/* 用户栏 */
.user-bar {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #d8c3a5;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(58, 43, 26, 0.06);
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #e8d5b8;
  background: #f0e6d6;
  flex-shrink: 0;
}

.user-avatar-text {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #e8d5b8;
  background: #f0e6d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #3a2b1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-hint {
  font-size: 22rpx;
  color: #9a8468;
  margin-top: 4rpx;
}

.user-arrow {
  font-size: 36rpx;
  color: #c4a882;
  margin-left: 8rpx;
}

/* 分区标题 */
.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #9a8468;
  margin-bottom: 12rpx;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* 游戏列表 */
.game-list {
  margin-bottom: 16rpx;
}

.game-row {
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx;
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #e8d5b8;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
  transition: transform 0.1s, background 0.1s;
}

.game-row:active {
  transform: scale(0.98);
  background: #fef5e7;
}

.pvp-row {
  border-color: #ddc09a;
  background: linear-gradient(135deg, #fffaf0 0%, #fef5e5 100%);
}

/* 图标 */
.game-icon-box {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.game-emoji {
  font-size: 40rpx;
}

/* 详情 */
.game-detail {
  flex: 1;
  margin-left: 18rpx;
  overflow: hidden;
}

.game-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.game-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3a2b1a;
}

.pvp-tag {
  font-size: 18rpx;
  color: #c97a3e;
  background: #f5e6d0;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.game-best {
  font-size: 22rpx;
  color: #c97a3e;
  font-weight: 700;
  margin-left: auto;
}

.game-tags {
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 18rpx;
  color: #b8a48a;
  background: #ede3d3;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
}

.game-arrow {
  font-size: 32rpx;
  color: #d0c0a8;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.bottom-space {
  height: 140rpx;
}

/* 骨架屏 — 列表形式 */
.skeleton-row {
  background: linear-gradient(90deg, #f0e6d6 25%, #f8f0e2 50%, #f0e6d6 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
  height: 96rpx;
  margin-bottom: 10rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
