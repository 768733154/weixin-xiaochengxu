.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6efe4 0%, #eadcc8 100%);
  padding: 0 28rpx;
}

/* 用户栏 */
.user-bar {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-top: 16rpx;
  margin-bottom: 28rpx;
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #d8c3a5;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(58, 43, 26, 0.06);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #e8d5b8;
  background: #f0e6d6;
  flex-shrink: 0;
}

.user-avatar-text {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #e8d5b8;
  background: #f0e6d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #3a2b1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-hint {
  font-size: 22rpx;
  color: #9a8468;
  margin-top: 4rpx;
}

.user-arrow {
  font-size: 36rpx;
  color: #c4a882;
  margin-left: 8rpx;
}

/* 分区标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #7a5a36;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* 游戏网格 */
.game-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.game-card {
  width: calc(50% - 8rpx);
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #e0d0b8;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 16rpx rgba(58, 43, 26, 0.05);
  transition: transform 0.12s, box-shadow 0.12s;
}

.game-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(58, 43, 26, 0.08);
}

.pvp-card {
  border-color: #ddc09a;
  background: linear-gradient(180deg, #fffaf0 0%, #fef2de 100%);
}

.game-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
}

.game-icon-emoji {
  font-size: 48rpx;
}

.pvp-badge {
  position: absolute;
  top: -4rpx;
  right: -8rpx;
  font-size: 18rpx;
}

.game-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #3a2b1a;
  margin-bottom: 6rpx;
}

.game-tags {
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.tag {
  font-size: 18rpx;
  color: #9a8468;
  background: #ede3d3;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
}

.game-best {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #c97a3e;
  font-weight: 600;
}

.bottom-space {
  height: 140rpx;
}
