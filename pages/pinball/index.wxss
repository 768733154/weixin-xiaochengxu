.pin-page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 170, 0.28), transparent 45%),
    radial-gradient(circle at 20% 20%, rgba(255, 153, 102, 0.2), transparent 46%),
    linear-gradient(180deg, #f5efe7 0%, #f1e0cf 45%, #f7f0e7 100%);
}

.panel {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fff5e5, #f7e1c7);
  border: none;
  box-shadow: 0 16rpx 40rpx rgba(129, 96, 64, 0.15);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  text-align: left;
  color: #4b2f1a;
}

.subtitle {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: rgba(75, 47, 26, 0.7);
}

.meta {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #7d5b37;
}

.status {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.6);
  text-align: center;
  font-size: 26rpx;
  color: #6a4b2a;
}

.arena-card {
  padding-bottom: 32rpx;
  background: linear-gradient(180deg, #fff 0%, #fdf1e3 100%);
  border: none;
  box-shadow: 0 20rpx 50rpx rgba(120, 80, 40, 0.1);
}

.arena {
  position: relative;
  height: 900rpx;
  overflow: hidden;
}

.disc-glow {
  position: absolute;
  left: 50%;
  top: 220rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(255, 234, 204, 0.7), transparent 68%);
  filter: blur(10rpx);
}

.disc-shadow {
  position: absolute;
  left: 50%;
  top: 300rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  transform: translateX(-50%);
  background: rgba(161, 120, 74, 0.2);
  filter: blur(20rpx);
}

.disc-wrap {
  position: absolute;
  left: 50%;
  top: 300rpx;
  width: 280rpx;
  height: 280rpx;
  transform: translateX(-50%);
}

.disc-core {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ffe9d2 0%, #f4c699 55%, #c07a43 100%);
  border: 10rpx solid rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 36rpx rgba(90, 64, 35, 0.28);
}

.disc-level {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a2a14;
}

.pin {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 0;
  height: 0;
}

.pin.attached {
  transform-origin: center center;
}

.pin-line {
  position: absolute;
  left: -4rpx;
  top: -200rpx;
  width: 8rpx;
  height: 200rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fdf6ea 0%, #d09a5e 100%);
  box-shadow: 0 4rpx 12rpx rgba(155, 104, 54, 0.2);
}

.pin-head {
  position: absolute;
  left: -16rpx;
  top: -226rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #ffb889, #ff6a3d 70%);
  box-shadow: 0 6rpx 16rpx rgba(255, 106, 61, 0.35);
}

.pin.current {
  left: 50%;
  bottom: 84rpx;
  top: auto;
  transform-origin: center bottom;
  transition: transform 180ms linear;
}

.queue {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  min-height: 36rpx;
  margin-top: 24rpx;
}

.queue-pin {
  width: 16rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fef1df, #c78248);
  box-shadow: 0 6rpx 10rpx rgba(146, 95, 50, 0.2);
}

.ctrl {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.fire-btn {
  flex: 1;
  background: linear-gradient(135deg, #ffb46a, #ff7e5f);
  color: #fff;
  box-shadow: 0 12rpx 20rpx rgba(255, 126, 95, 0.3);
}

.retry-btn {
  flex: 1;
  background: linear-gradient(135deg, #f66d6d, #d94141);
  color: #fff;
}

.restart-btn {
  flex: 1;
  background: linear-gradient(135deg, #5ec49e, #2f8f68);
  color: #fff;
}

.hint {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(74, 51, 27, 0.7);
}

.fail-text {
  margin-top: 16rpx;
  text-align: center;
  color: #c8473d;
  font-size: 26rpx;
}

.leaderboard-card {
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: none;
  box-shadow: 0 20rpx 50rpx rgba(90, 60, 30, 0.12);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #59371d;
}

.section-title.sub {
  margin-top: 28rpx;
}

.best-box {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(255, 217, 176, 0.4), rgba(255, 238, 213, 0.9));
}

.best-level {
  font-size: 30rpx;
  font-weight: 600;
  color: #5a3416;
}

.best-meta {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  color: rgba(74, 51, 27, 0.7);
  font-size: 24rpx;
}

.leader-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx dashed rgba(90, 55, 25, 0.15);
}

.leader-item:last-child {
  border-bottom: none;
}

.rank-no {
  width: 60rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #c46a3d;
}

.leader-main {
  flex: 1;
}

.leader-label {
  font-size: 28rpx;
  color: #422819;
}

.leader-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(74, 51, 27, 0.7);
}

.leader-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d7f62;
}

.empty {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(74, 51, 27, 0.6);
}
