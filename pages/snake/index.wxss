.snake-page {
  min-height: 100vh;
  padding-bottom: 56rpx;
  background:
    radial-gradient(circle at top left, rgba(110, 143, 255, 0.26), transparent 34%),
    radial-gradient(circle at top right, rgba(67, 232, 181, 0.22), transparent 30%),
    linear-gradient(180deg, #0f172a 0%, #111827 48%, #07111f 100%);
  color: #f8fafc;
}

.hero-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.eyebrow {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(148, 163, 184, 0.9);
}

.title {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1.1;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(226, 232, 240, 0.72);
}

.status-chip {
  align-self: flex-start;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.48);
  border: 2rpx solid rgba(148, 163, 184, 0.2);
  color: #cbd5e1;
  backdrop-filter: blur(18rpx);
}

.status-chip.active {
  color: #dcfce7;
  border-color: rgba(74, 222, 128, 0.36);
  box-shadow: 0 0 30rpx rgba(74, 222, 128, 0.18);
}

.status-chip.danger {
  color: #ffe4e6;
  border-color: rgba(251, 113, 133, 0.36);
  box-shadow: 0 0 30rpx rgba(251, 113, 133, 0.18);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(15, 23, 42, 0.48);
  border: 2rpx solid rgba(148, 163, 184, 0.12);
  box-shadow: 0 16rpx 44rpx rgba(15, 23, 42, 0.26);
  backdrop-filter: blur(18rpx);
}

.stat-label {
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.92);
}

.stat-value {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #f8fafc;
}

.stat-value.small {
  font-size: 34rpx;
}

.game-shell.card {
  padding: 24rpx;
  border: 2rpx solid rgba(148, 163, 184, 0.12);
  background: rgba(15, 23, 42, 0.62);
  box-shadow: 0 24rpx 60rpx rgba(2, 6, 23, 0.38);
  backdrop-filter: blur(20rpx);
}

.board-frame {
  position: relative;
  padding: 16rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.9));
  border: 2rpx solid rgba(96, 165, 250, 0.12);
}

.board-glow {
  position: absolute;
  inset: -80rpx;
  background: radial-gradient(circle, rgba(56, 189, 248, 0.16), transparent 54%);
  pointer-events: none;
}

.board {
  position: relative;
  display: grid;
  grid-template-columns: repeat(16, 1fr);
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(2, 6, 23, 0.92));
}

.cell {
  width: 100%;
  padding-top: 100%;
  height: 0;
  border-radius: 12rpx;
  background: rgba(148, 163, 184, 0.08);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.02);
}

.snake {
  background: linear-gradient(135deg, #34d399, #10b981);
  box-shadow: 0 0 18rpx rgba(16, 185, 129, 0.4);
}

.head {
  background: linear-gradient(135deg, #67e8f9, #22d3ee 55%, #06b6d4);
  box-shadow: 0 0 22rpx rgba(34, 211, 238, 0.55);
}

.food {
  background: radial-gradient(circle at 35% 35%, #fef3c7, #fb7185 45%, #e11d48 100%);
  border-radius: 50%;
  box-shadow: 0 0 22rpx rgba(244, 63, 94, 0.45);
}

.hint {
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(148, 163, 184, 0.88);
}

.ctrl {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.modern-ctrl .action-btn {
  flex: 1;
  margin: 0;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.modern-ctrl .action-btn::after,
.modern-pad .pad-btn::after {
  border: none;
}

.modern-ctrl .primary {
  color: #04111f;
  background: linear-gradient(135deg, #67e8f9, #34d399);
  box-shadow: 0 12rpx 28rpx rgba(52, 211, 153, 0.28);
}

.modern-ctrl .ghost {
  color: #e2e8f0;
  background: rgba(30, 41, 59, 0.9);
}

.modern-pad {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.row {
  display: flex;
  gap: 18rpx;
}

.modern-pad .pad-btn {
  width: 132rpx;
  height: 132rpx;
  margin: 0;
  border-radius: 36rpx;
  background: rgba(30, 41, 59, 0.94);
  color: #f8fafc;
  font-size: 44rpx;
  font-weight: 700;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.08), 0 16rpx 30rpx rgba(2, 6, 23, 0.3);
}

.modern-pad .pad-btn.vertical {
  width: 180rpx;
  height: 112rpx;
}
