<view class="container">
  <view class="card">
    <view class="meta">
      <text>分数 {{score}}</text>
      <text>速度 {{speed}}ms</text>
    </view>
    <view class="board">
      <view wx:for="{{cells}}" wx:key="index" class="cell {{item}}"></view>
    </view>
    <view class="ctrl">
      <button class="btn" bindtap="start">开始</button>
      <button class="btn" bindtap="pause">暂停</button>
      <button class="btn" bindtap="reset">重开</button>
    </view>
    <view class="dpad">
      <button bindtap="up">上</button>
      <view class="row">
        <button bindtap="left">左</button>
        <button bindtap="right">右</button>
      </view>
      <button bindtap="down">下</button>
    </view>
  </view>
</view>
