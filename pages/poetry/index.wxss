.panel {
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
  color: #5a4023;
}

.level-badge {
  width: fit-content;
  margin: 18rpx auto 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f3e2c6;
  color: #7b572f;
  font-size: 24rpx;
  font-weight: 600;
}

.meta {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  color: #7d5b37;
  font-size: 26rpx;
}

.question-card {
  min-height: 600rpx;
}

.question {
  font-size: 34rpx;
  line-height: 1.7;
  font-weight: 600;
  color: #3f2c17;
}

.options {
  margin-top: 28rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 22rpx;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid #d8c3a5;
  background: #fffdf8;
}

.opt-prefix {
  margin-right: 16rpx;
  font-weight: 700;
  color: #7a5834;
}

.selected {
  border-color: #b18a61;
  background: #f8eddc;
}

.right {
  border-color: #3d8b4f;
  background: #e9f7ec;
}

.wrong {
  border-color: #b0413e;
  background: #fdeceb;
}

.message {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #694b2b;
}

.next {
  background: #7a5834;
  color: #fff;
}

.restart {
  background: #2d6a4f;
  color: #fff;
}
