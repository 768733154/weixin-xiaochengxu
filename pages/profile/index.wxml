<view class="container">
  <!-- 用户信息 -->
  <view class="card profile-card">
    <view class="profile-avatar-text" wx:if="{{!userInfo.avatarUrl}}">👤</view>
    <image class="profile-avatar" wx:elif="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.nickName || '游客'}}</text>
      <text class="profile-stat">已挑战 {{totalGames}} 款游戏</text>
    </view>
    <button wx:if="{{!userInfo.authorized}}" class="login-btn" bindtap="onTapLogin">登录</button>
  </view>

  <!-- 最佳战绩 -->
  <view class="card best-card" wx:if="{{bestGame && bestGame.score > 0}}">
    <text class="best-label">最佳战绩</text>
    <text class="best-game">{{bestGame.name}}</text>
    <text class="best-score">{{bestGame.score}} 分</text>
  </view>

  <!-- 各游戏分数 -->
  <view class="section-title">游戏成绩</view>
  <view class="score-list">
    <view class="score-item card" wx:for="{{gameScores}}" wx:key="id">
      <view class="score-left">
        <text class="score-name">{{item.name}}</text>
        <text class="score-cat">{{item.category === 'pvp' ? '对战' : '单人'}}</text>
      </view>
      <text class="score-val">{{item.score > 0 ? item.score + ' 分' : '未挑战'}}</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="card setting-card" bindtap="clearCache">
    <text class="setting-text">清除本地缓存</text>
  </view>
</view>
