.profile-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #d8c3a5;
  background: #f0e6d6;
}

.profile-avatar-text {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #d8c3a5;
  background: #f0e6d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #3a2b1a;
}

.profile-stat {
  font-size: 24rpx;
  color: #9a8468;
  margin-top: 6rpx;
}

.login-btn {
  background: #7a5834;
  color: #fff;
  font-size: 26rpx;
  border-radius: 999rpx;
  padding: 10rpx 32rpx;
}

.best-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  border-color: #c97a3e;
  background: linear-gradient(180deg, #fff8ed 0%, #fef0da 100%);
}

.best-label {
  font-size: 24rpx;
  color: #9a8468;
}

.best-game {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #3a2b1a;
}

.best-score {
  font-size: 34rpx;
  font-weight: 700;
  color: #c97a3e;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5a4023;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.score-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.score-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a2b1a;
}

.score-cat {
  font-size: 20rpx;
  color: #9a8468;
  background: #f0e6d6;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}

.score-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #c97a3e;
}

.setting-card {
  margin-top: 40rpx;
  padding: 24rpx;
  text-align: center;
}

.setting-text {
  font-size: 28rpx;
  color: #b0413e;
}
