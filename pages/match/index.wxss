.match-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  margin-top: 60rpx;
}

.match-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #3a2b1a;
  margin-bottom: 24rpx;
}

.match-text {
  font-size: 30rpx;
  color: #7a5a36;
  margin-top: 20rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e8d5b8;
  border-top-color: #7a5834;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.room-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 24rpx 0;
}

.room-label {
  font-size: 24rpx;
  color: #9a8468;
}

.room-id {
  font-size: 44rpx;
  font-weight: 800;
  color: #c97a3e;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

.waiting-actions {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 0;
}

.action-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 40rpx;
  border: none;
}

.copy {
  background: #7a5834;
  color: #fff;
}

.share {
  background: #c97a3e;
  color: #fff;
}

.cancel {
  background: #e8d5b8;
  color: #7a5a36;
  margin-top: 20rpx;
}

.retry {
  background: #7a5834;
  color: #fff;
  margin-top: 20rpx;
}

.match-hint {
  font-size: 24rpx;
  color: #9a8468;
  margin-top: 16rpx;
}

.match-timer {
  font-size: 60rpx;
  font-weight: 800;
  color: #7a5834;
  margin: 16rpx 0;
}

.success {
  border-color: #3d8b4f;
  background: linear-gradient(180deg, #f0faf2 0%, #e2f5e6 100%);
}

.success-text {
  color: #3d8b4f;
}

.error {
  border-color: #b0413e;
}

.error-text {
  color: #b0413e;
}
