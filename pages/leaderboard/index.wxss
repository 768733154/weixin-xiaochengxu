.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6efe4 0%, #eadcc8 100%);
  padding: 28rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.game-picker {
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #e0d0b8;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
}

.picker-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #5a4023;
}

.tab-switch {
  display: flex;
  border-radius: 999rpx;
  overflow: hidden;
  border: 2rpx solid #e0d0b8;
}

.tab-btn {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  color: #9a8468;
  background: rgba(255, 250, 242, 0.95);
  transition: all 0.15s;
}

.tab-btn.active {
  background: #7a5834;
  color: #fff;
}

/* 排行列表 */
.rank-list {
  margin-top: 8rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 250, 242, 0.95);
  border: 2rpx solid #e8d5b8;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  transition: transform 0.1s;
}

.rank-item.is-me {
  border-color: #ddc09a;
  background: linear-gradient(135deg, #fffaf0 0%, #fef2de 100%);
  box-shadow: 0 4rpx 12rpx rgba(201, 122, 62, 0.12);
}

.rank-num {
  width: 56rpx;
  text-align: center;
  flex-shrink: 0;
}

.medal {
  font-size: 36rpx;
}

.rank-idx {
  font-size: 28rpx;
  font-weight: 700;
  color: #b8a48a;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-left: 16rpx;
  border: 2rpx solid #e8d5b8;
  background: #f0e6d6;
  flex-shrink: 0;
}

.rank-avatar-text {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-left: 16rpx;
  border: 2rpx solid #e8d5b8;
  background: #f0e6d6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.rank-name {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #3a2b1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-score {
  font-size: 30rpx;
  font-weight: 700;
  color: #c97a3e;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #7a5a36;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #b8a48a;
}
