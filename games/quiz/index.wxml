<view class="container">
  <view class="card panel">
    <view class="title">怀古诗词闯关</view>
    <view class="meta">
      <text>第 {{current}} / {{total}} 题</text>
      <text>得分 {{score}}</text>
      <text>剩余 {{timeLeft}}s</text>
    </view>
  </view>

  <view class="card question-card" wx:if="{{question}}">
    <view class="question">{{question.title}}</view>

    <view class="options">
      <view
        class="option {{selected === index ? 'selected' : ''}} {{answered && index === question.answer ? 'right' : ''}} {{answered && selected === index && index !== question.answer ? 'wrong' : ''}}"
        wx:for="{{question.options}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="chooseOption"
      >
        <text class="opt-prefix">{{String.fromCharCode(65 + index)}}.</text>
        <text>{{item}}</text>
      </view>
    </view>

    <view class="message" wx:if="{{message}}">{{message}}</view>

    <button class="btn next" wx:if="{{answered && !gameOver}}" bindtap="nextQuestion">下一题</button>
  </view>

  <!-- 游戏结束弹窗 -->
  <view class="over-mask" wx:if="{{showOverModal}}" catchtouchmove="true">
    <view class="over-modal">
      <text class="over-emoji">📜</text>
      <text class="over-title">{{overTip}}</text>
      <view class="over-stats">
        <view class="over-stat">
          <text class="over-stat-val">{{overScore}}</text>
          <text class="over-stat-label">得分</text>
        </view>
        <view class="over-stat">
          <text class="over-stat-val">{{overBest}}</text>
          <text class="over-stat-label">最高</text>
        </view>
      </view>
      <view class="over-actions">
        <view class="over-btn over-restart" bindtap="overRestart">再来一局</view>
        <view class="over-btn over-back" bindtap="overBack">返回大厅</view>
      </view>
    </view>
  </view>
</view>
