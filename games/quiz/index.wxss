.panel {
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
  color: #5a4023;
}

.meta {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  color: #7d5b37;
  font-size: 26rpx;
}

.question-card {
  min-height: 600rpx;
}

.question {
  font-size: 34rpx;
  line-height: 1.7;
  font-weight: 600;
  color: #3f2c17;
}

.options {
  margin-top: 28rpx;
}

.option {
  display: flex;
  align-items: center;
  padding: 22rpx;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid #d8c3a5;
  background: #fffdf8;
}

.opt-prefix {
  margin-right: 16rpx;
  font-weight: 700;
  color: #7a5834;
}

.selected {
  border-color: #b18a61;
  background: #f8eddc;
}

.right {
  border-color: #3d8b4f;
  background: #e9f7ec;
}

.wrong {
  border-color: #b0413e;
  background: #fdeceb;
}

.message {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #694b2b;
}

.next {
  background: #7a5834;
  color: #fff;
}

/* 游戏结束弹窗 */
.over-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.over-modal {
  width: 540rpx;
  background: rgba(255, 250, 242, 0.98);
  border: 2rpx solid #d8c3a5;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.over-emoji {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.over-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #3a2b1a;
  margin-bottom: 32rpx;
}

.over-stats {
  display: flex;
  gap: 60rpx;
  margin-bottom: 36rpx;
}

.over-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.over-stat-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #c97a3e;
}

.over-stat-label {
  font-size: 22rpx;
  color: #9a8468;
  margin-top: 4rpx;
}

.over-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.over-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.over-restart {
  background: #6b4c8a;
  color: #fff;
}

.over-back {
  background: transparent;
  color: #9a8468;
  border: 2rpx solid #d8c3a5;
}
