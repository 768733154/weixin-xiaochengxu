.meta { display:flex; justify-content:space-between; margin-bottom:16rpx; }
.board { display:grid; grid-template-columns:repeat(16, 1fr); gap:4rpx; background:#b69a78; padding:8rpx; border-radius:12rpx; }
.cell { width: 36rpx; height: 36rpx; background:#f9f1e5; }
.snake { background:#7a5834; }
.head { background:#50361e; }
.food { background:#b13e3c; border-radius:50%; }
.ctrl { display:flex; gap:10rpx; margin-top:16rpx; }
.ctrl .btn { flex:1; background:#7a5834; color:#fff; }
.dpad { margin-top:16rpx; display:flex; flex-direction:column; align-items:center; gap:8rpx; }
.row { display:flex; gap:20rpx; }
.dpad button { width:120rpx; }

/* 游戏结束弹窗 */
.over-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.over-modal {
  width: 540rpx;
  background: rgba(255, 250, 242, 0.98);
  border: 2rpx solid #d8c3a5;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.over-emoji {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.over-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #3a2b1a;
  margin-bottom: 32rpx;
}

.over-stats {
  display: flex;
  gap: 60rpx;
  margin-bottom: 36rpx;
}

.over-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.over-stat-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #c97a3e;
}

.over-stat-label {
  font-size: 22rpx;
  color: #9a8468;
  margin-top: 4rpx;
}

.over-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.over-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.over-restart {
  background: #7a5834;
  color: #fff;
}

.over-back {
  background: transparent;
  color: #9a8468;
  border: 2rpx solid #d8c3a5;
}
