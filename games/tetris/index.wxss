.arcade-page {
  min-height: 100vh;
  height: 100vh;
  box-sizing: border-box;
  padding: 20rpx;
  background:
    radial-gradient(circle at 20% 10%, rgba(255, 74, 164, 0.2), transparent 35%),
    radial-gradient(circle at 80% 90%, rgba(58, 236, 255, 0.2), transparent 35%),
    linear-gradient(180deg, #12132a 0%, #06070f 100%);
}

.cabinet {
  height: 100%;
  display: flex;
  flex-direction: column;
  border-radius: 26rpx;
  padding: 18rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(255, 70, 70, 0.2) 0 14%, transparent 14% 28%, rgba(70, 160, 255, 0.2) 28% 42%, transparent 42% 56%, rgba(255, 215, 80, 0.2) 56% 70%, transparent 70% 84%, rgba(255, 70, 70, 0.2) 84% 100%),
    linear-gradient(180deg, #3a3f52 0%, #2d3142 100%);
  border: 4rpx solid #f6c15c;
  box-shadow:
    0 0 0 6rpx rgba(246, 193, 92, 0.22),
    0 20rpx 38rpx rgba(0, 0, 0, 0.45),
    inset 0 0 26rpx rgba(255, 210, 112, 0.2);
}

.cabinet-top {
  text-align: center;
  margin-bottom: 12rpx;
}

.brand {
  color: #ffd36b;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow: 0 0 10rpx rgba(255, 224, 111, 0.7);
}

.sub {
  margin-top: 4rpx;
  color: #ff8cae;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.screen-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #6f7687 0%, #525969 100%);
  border: 2rpx solid #adb6c9;
}

.meta {
  display: flex;
  justify-content: space-between;
  color: #ecf2ff;
  font-size: 24rpx;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.screen {
  position: relative;
  flex: 1;
  min-height: 0;
  border-radius: 10rpx;
  padding: 8rpx;
  background: radial-gradient(circle at 50% 35%, #11452d 0%, #072516 60%, #04150d 100%);
  border: 2rpx solid #89ffa0;
  box-shadow: inset 0 0 24rpx rgba(110, 255, 148, 0.35);
  overflow: hidden;
}

.scanlines {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: repeating-linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.15) 0,
    rgba(0, 0, 0, 0.15) 2rpx,
    rgba(0, 0, 0, 0) 4rpx,
    rgba(0, 0, 0, 0) 8rpx
  );
  z-index: 3;
}

.board {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  grid-template-rows: repeat(20, 1fr);
  gap: 2rpx;
}

.playfield {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.side-decor {
  height: 100%;
  flex: 1;
  min-width: 18rpx;
  border-radius: 8rpx;
  background:
    repeating-linear-gradient(
      135deg,
      rgba(255, 84, 112, 0.45) 0,
      rgba(255, 84, 112, 0.45) 8rpx,
      rgba(83, 177, 255, 0.45) 8rpx,
      rgba(83, 177, 255, 0.45) 16rpx,
      rgba(255, 216, 110, 0.45) 16rpx,
      rgba(255, 216, 110, 0.45) 24rpx
    ),
    linear-gradient(180deg, rgba(42, 47, 60, 0.5) 0%, rgba(22, 26, 36, 0.5) 100%);
  box-shadow:
    inset 0 0 12rpx rgba(255, 255, 255, 0.18),
    0 0 8rpx rgba(255, 160, 80, 0.25);
}

.cell {
  background: #103420;
  border: 1rpx solid rgba(144, 255, 170, 0.15);
}

.filled {
  background: linear-gradient(180deg, #a7ff75 0%, #4ef24a 100%);
  box-shadow: inset 0 -4rpx 0 rgba(24, 97, 26, 0.6), 0 0 10rpx rgba(126, 255, 114, 0.65);
}

.panel {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #272d3d 0%, #1a1f2b 100%);
  border: 2rpx solid #8f9ab1;
}

.func-row {
  display: flex;
  gap: 14rpx;
}

.btn-func {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffe28a;
  background: linear-gradient(180deg, #3d6cf0 0%, #2b4cb0 100%);
  color: #f8fbff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: inset 0 -6rpx 0 rgba(0, 0, 0, 0.3);
}

.controls {
  margin-top: 12rpx;
  display: flex;
  justify-content: center;
}

.dpad {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.mid-row {
  width: 100%;
  display: flex;
  justify-content: space-between;
}

.btn-dir {
  width: 30%;
  min-width: 150rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 16rpx;
  border: 2rpx solid #ffcf63;
  background: linear-gradient(180deg, #e1524b 0%, #a9312b 100%);
  color: #fff7e6;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: inset 0 -8rpx 0 rgba(0, 0, 0, 0.28);
}

.up,
.down {
  width: 40%;
}
