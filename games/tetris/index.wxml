<view class="arcade-page">
  <view class="cabinet">
    <view class="cabinet-top">
      <view class="brand">怀古方块机</view>
      <view class="sub">八十年代街机风</view>
    </view>

    <view class="screen-shell">
      <view class="meta">
        <text>分数 {{score}}</text>
        <text>消行 {{lines}}</text>
      </view>

      <view class="screen">
        <view class="scanlines"></view>
        <view class="playfield">
          <view class="side-decor left"></view>
          <view class="board" style="{{boardStyle}}">
            <view wx:for="{{cells}}" wx:key="index" class="cell {{item ? 'filled' : ''}}"></view>
          </view>
          <view class="side-decor right"></view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="func-row">
        <button size="mini" class="btn-func" bindtap="start">开始</button>
        <button size="mini" class="btn-func" bindtap="pause">暂停</button>
      </view>

      <view class="controls">
        <view class="dpad">
          <button class="btn-dir up" bindtap="rotate">旋转</button>
          <view class="mid-row">
            <button
              class="btn-dir"
              bindtap="left"
              bindtouchstart="startFastLeft"
              bindtouchend="stopFastLeft"
              bindtouchcancel="stopFastLeft"
            >左移</button>
            <button
              class="btn-dir"
              bindtap="right"
              bindtouchstart="startFastRight"
              bindtouchend="stopFastRight"
              bindtouchcancel="stopFastRight"
            >右移</button>
          </view>
          <button
            class="btn-dir down"
            bindtap="down"
            bindtouchstart="startFastDrop"
            bindtouchend="stopFastDrop"
            bindtouchcancel="stopFastDrop"
          >下落</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 游戏结束弹窗 -->
  <view class="over-mask" wx:if="{{showOverModal}}" catchtouchmove="true">
    <view class="over-modal">
      <text class="over-title">游戏结束</text>
      <view class="over-stats">
        <view class="over-stat">
          <text class="over-stat-val">{{overScore}}</text>
          <text class="over-stat-label">得分</text>
        </view>
        <view class="over-stat">
          <text class="over-stat-val">{{overLines}}</text>
          <text class="over-stat-label">消行</text>
        </view>
        <view class="over-stat">
          <text class="over-stat-val">{{overBest}}</text>
          <text class="over-stat-label">最高</text>
        </view>
      </view>
      <view class="over-actions">
        <view class="over-btn over-restart" bindtap="overRestart">再来一局</view>
        <view class="over-btn over-back" bindtap="overBack">返回大厅</view>
      </view>
    </view>
  </view>
</view>
